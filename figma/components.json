{
  "$schema": "http://jsonschema.org/draft-07/schema#",
  "title": "Restaurant App UI Schema",
  "type": "object",
  "properties": {
    "restaurantCard": {
      "type": "object",
      "properties": {
        "background": {
          "type": "string",
          "value": "#FFFFFF"
        },
        "shadow": {
          "type": "string",
          "value": "0px 4px 4px rgba(0, 0, 0, 0.1)"
        },
        "borderRadius": {
          "type": "array",
          "value": [12, 12, 0, 0]
        },
        "image": {
          "type": "object",
          "properties": {
            "position": {
              "left": "50%",
              "top": "50%",
              "transform": "translate(-50%, -66%)"
            },
            "height": 132,
            "width": 343,
            "placeholder": "#FFFFFF",
            "background": "url(placeholder-image.png)"
          }
        },
        "tags": {
          "type": "array",
          "description": "Tag • Tag • Tag",
          "style": {
            "font-family": "Helvetica",
            "fontWeight": 700,
            "fontSize": 12,
            "alignments": "flex-start",
            "gap": 4
          }
        },
        "time": {
          "type": "string",
          "value": "30 mins",
          "style": {
            "fontWeight": 700,
            "fontSize": 10,
            "marginTop": 4,
            "iconWidth": 20,
            "iconHeight": 20,
            "iconColor": "red"
          }
        },
        "rating": {
          "type": "object",
          "properties": {
            "stars": {
              "colors": "#F9CA24",
              "count": 5,
              "iconSize": 12
            },
            "score": {
              "type": "number",
              "value": 5.0,
              "style": {
                "fontWeight": 700,
                "fontSize": 10,
                "marginTop": 4
              }
            }
          }
        },
        "infoText": {
          "type": "string",
          "value": "30 mins - 1.2 km",
          "style": {
            "fontWeight": 500,
            "fontSize": 10,
            "marginTop": 4
          }
        },
        "badge": {
          "type": "object",
          "properties": {
            "icon": {
              "type": "string",
              "value": "gold-ribbon-red",
              "style": {
                "width": 2,
                "height": 2,
                "fillType": "red",
                "borderRadius": "0.8"
              }
            }
          }
        }
      }
    },
    "titleCard": {
      "type": "object",
      "properties": {
        "background": {
          "type": "string",
          "value": "#FFFFFF"
        },
        "shadow": {
          "type": "string",
          "value": "0px 4px 4px rgba(0, 0, 0, 0.1)"
        },
        "borderRadius": {
          "type": "array",
          "value": [12, 12, 12, 12]
        },
        "mainTitle": {
          "type": "string",
          "style": {
            "fontSize": 24,
            "fontWeight": 400,
            "marginTop": 16,
            "marginBottom": 26
          }
        },
        "subtitle": {
          "type": "string",
          "style": {
            "fontWeight": 400,
            "fontSize": 16,
            "marginTop": 26
          }
        },
        "statusTexts": {
          "type": "array",
          "items": [{
            "type": "object",
            "properties": {
              "text": "Open",
              "color": "#2ECC71"
            }
          }, {
            "type": "object",
            "properties": {
              "text": "Closed",
              "color": "#8B0000"
            }
          }]
        }
      }
    },
    "filters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "base": {
            "type": "object",
            "properties": {
              "position": {
                "width": 144,
                "height": 48
              },
              "间隔": 8,
              "borderRadius": 24
            }
          }
        }
      }
    },
    "filterUnselected": {
      "type": "object",
      "properties": {
        "bg": "rgba(255,255,255,0.4)",
        "shadow": "0px 4px 10px rgba(0,0,0,0.04)",
        "iconColor": "#000000",
        "titleColor": "#000000"
      }
    },
    "filterSelected": {
      "type": "object",
      "properties": {
        "bg": "#E2A364",
        "shadow": "0px 4px 10px rgba(0,0,0,0.04)",
        "iconColor": "#FFFFFF",
        "titleColor": "#FFFFFF"
      }
    }
  }
}
